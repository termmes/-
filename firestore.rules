rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        (request.auth.token.email == "kblox05@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isMember() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'member';
    }

    function canEditCatalog() {
      return isAdmin() || isMember();
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function uidUnchanged() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid;
    }

    function uidNotModified() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function areValidVariations(variations) {
      return variations is list && variations.size() <= 50;
    }

    function isValidUserProfile() {
      return hasOnlyAllowedFields(['uid', 'displayName', 'photoUrl', 'updatedAt', 'role']) &&
             validStringLength('displayName', 1, 100) &&
             validStringLength('photoUrl', 0, 1000000) &&
             request.resource.data.uid is string &&
             request.resource.data.updatedAt is timestamp &&
             (!('role' in request.resource.data) || request.resource.data.role in ['admin', 'member', 'user']);
    }

    function isValidProduct() {
      return hasOnlyAllowedFields(['name', 'imageUrl', 'variations', 'ownerId', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('imageUrl', 0, 1000000) && // Allow large base64 images
             areValidVariations(request.resource.data.variations) &&
             request.resource.data.ownerId is string &&
             request.resource.data.createdAt is timestamp;
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow delete: if canEditCatalog();
      allow create: if canEditCatalog() && 
                       isValidProduct() && 
                       uidUnchanged() && 
                       request.resource.data.ownerId == request.auth.uid;
      allow update: if canEditCatalog() && 
                       isValidProduct() && 
                       uidNotModified() && 
                       request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       request.auth.uid == userId && 
                       isValidUserProfile() && 
                       request.resource.data.uid == request.auth.uid &&
                       (
                         !('role' in request.resource.data) || 
                         request.resource.data.role == 'user' || 
                         isAdmin()
                       );
      allow update: if isAuthenticated() && 
                       isValidUserProfile() && 
                       request.resource.data.uid == resource.data.uid &&
                       (
                         (request.auth.uid == userId && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) ||
                         isAdmin()
                       );
    }
  }
}
